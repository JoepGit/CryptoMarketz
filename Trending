<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Trending Intelligence — Astro Intelligence Trading Desk</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#eef2f7;--card:#fff;--text:#0a1929;--sub:#5f7494;--bdr:rgba(15,40,80,.11);--muted:#f4f7fb;--blue:#0055ff;--green:#00c48c;--red:#e53e3e;--teal:#00d4aa;}
body{font-family:'Plus Jakarta Sans',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:rgba(15,40,80,.13);border-radius:3px}

/* NAV */
.nav{position:sticky;top:0;z-index:50;background:rgba(238,242,247,.97);border-bottom:1px solid var(--bdr);backdrop-filter:blur(12px);padding:0 28px;height:52px;display:flex;align-items:center;gap:14px;}
.nav a.brand{font-size:14px;font-weight:800;color:var(--text);text-decoration:none;} .nav a.brand span{color:var(--blue);}
.nav-sep{width:1px;height:16px;background:var(--bdr);}
.nav-label{font-size:13px;font-weight:600;color:var(--sub);}
.live-dot{width:6px;height:6px;border-radius:50%;background:var(--green);display:inline-block;margin-right:5px;animation:blink 2.5s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.nav-updated{margin-left:4px;font-size:11px;color:var(--sub);}
.nav-back{margin-left:auto;font-size:12px;font-weight:600;color:var(--blue);text-decoration:none;padding:6px 14px;border:1px solid rgba(0,85,255,.2);border-radius:7px;background:rgba(0,85,255,.04);transition:all .15s;}
.nav-back:hover{background:var(--blue);color:#fff;}

/* LAYOUT */
.wrap{max-width:1260px;margin:0 auto;padding:26px 22px 60px;}

/* HERO */
.hero{background:var(--card);border:1px solid var(--bdr);border-radius:14px;padding:28px 32px;margin-bottom:22px;position:relative;overflow:hidden;box-shadow:0 1px 3px rgba(15,40,80,.05),0 6px 20px rgba(15,40,80,.04);}
.hero::after{content:'';position:absolute;top:0;right:0;width:360px;height:180px;background:radial-gradient(ellipse at top right,rgba(0,85,255,.05),transparent 65%);pointer-events:none;}
.hero-kicker{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.hero-kicker::before{content:'';width:18px;height:1px;background:var(--blue);}
.hero-hl{font-size:clamp(18px,2.8vw,28px);font-weight:800;letter-spacing:-.025em;line-height:1.15;margin-bottom:10px;}
.hero-summary{font-size:14px;color:var(--sub);line-height:1.75;max-width:700px;margin-bottom:16px;}
.hero-row{display:flex;align-items:flex-start;gap:12px;flex-wrap:wrap;}
.risk-pill{font-size:11px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;padding:4px 12px;border-radius:999px;flex-shrink:0;}
.risk-low{background:rgba(0,196,140,.09);border:1px solid rgba(0,196,140,.2);color:#008f6e;}
.risk-medium{background:rgba(0,85,255,.08);border:1px solid rgba(0,85,255,.2);color:var(--blue);}
.risk-high{background:rgba(232,120,32,.09);border:1px solid rgba(232,120,32,.22);color:#b04a00;}
.risk-extreme{background:rgba(229,62,62,.09);border:1px solid rgba(229,62,62,.2);color:var(--red);}
.analyst{font-size:13px;color:var(--sub);border-left:3px solid var(--blue);padding:9px 14px;border-radius:0 8px 8px 0;background:var(--muted);line-height:1.65;margin-top:14px;}
.analyst strong{color:var(--text);}

/* SOURCE TABS */
.tabs{display:flex;gap:0;border-bottom:1px solid var(--bdr);background:var(--card);border-radius:12px 12px 0 0;overflow:hidden;}
.tab{flex:1;padding:11px 8px;font-size:11px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--sub);cursor:pointer;border:none;background:transparent;border-bottom:2px solid transparent;transition:all .15s;display:flex;align-items:center;justify-content:center;gap:5px;}
.tab:hover{color:var(--text);background:var(--muted);}
.tab.on{color:var(--blue);border-bottom-color:var(--blue);background:#fff;}
.tab-icon{font-size:14px;}

/* MAIN GRID */
.grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:18px;}
.grid-wide{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:18px;}

/* CARDS */
.card{background:var(--card);border:1px solid var(--bdr);border-radius:12px;box-shadow:0 1px 3px rgba(15,40,80,.05),0 4px 12px rgba(15,40,80,.04);}
.card-hd{padding:11px 16px;border-bottom:1px solid var(--bdr);background:var(--muted);border-radius:12px 12px 0 0;display:flex;align-items:center;justify-content:space-between;}
.card-title{font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--sub);}
.badge{font-size:9px;font-weight:700;padding:2px 8px;border-radius:20px;}
.b-blue{background:rgba(0,85,255,.08);border:1px solid rgba(0,85,255,.18);color:var(--blue);}
.b-teal{background:rgba(0,212,170,.08);border:1px solid rgba(0,212,170,.18);color:#007a60;}
.b-green{background:rgba(0,196,140,.08);border:1px solid rgba(0,196,140,.18);color:#008f6e;}
.b-red{background:rgba(229,62,62,.08);border:1px solid rgba(229,62,62,.18);color:var(--red);}
.b-purple{background:rgba(100,60,200,.08);border:1px solid rgba(100,60,200,.18);color:#5030b0;}

/* NARRATIVE PILLS */
.narratives{padding:12px 16px;display:flex;flex-direction:column;gap:7px;}
.npill{display:flex;align-items:center;gap:9px;padding:8px 12px;background:var(--muted);border:1px solid var(--bdr);border-radius:8px;font-size:13px;color:var(--text);font-weight:500;}
.npill::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--blue);flex-shrink:0;}

/* THEMES */
.themes{padding:12px 16px;display:flex;flex-wrap:wrap;gap:7px;}
.theme{padding:4px 11px;border-radius:999px;font-size:12px;font-weight:600;background:var(--muted);border:1px solid var(--bdr);color:var(--sub);transition:all .12s;}
.theme:hover{background:rgba(0,85,255,.07);border-color:rgba(0,85,255,.15);color:var(--blue);}

/* AIRDROPS */
.airdrop{padding:12px 16px;border-bottom:1px solid var(--bdr);}
.airdrop:last-child{border-bottom:none;}
.airdrop-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;}
.airdrop-name{font-size:13px;font-weight:700;}
.airdrop-tags{display:flex;gap:5px;}
.hype-high{font-size:9px;font-weight:700;padding:2px 7px;border-radius:999px;background:rgba(229,62,62,.08);border:1px solid rgba(229,62,62,.2);color:var(--red);}
.hype-medium{font-size:9px;font-weight:700;padding:2px 7px;border-radius:999px;background:rgba(0,85,255,.08);border:1px solid rgba(0,85,255,.2);color:var(--blue);}
.hype-low{font-size:9px;font-weight:700;padding:2px 7px;border-radius:999px;background:rgba(15,40,80,.05);border:1px solid var(--bdr);color:var(--sub);}
.a-status{font-size:9px;font-weight:700;padding:2px 7px;border-radius:999px;background:rgba(0,196,140,.08);border:1px solid rgba(0,196,140,.2);color:#008f6e;}
.a-ended{background:rgba(15,40,80,.05);border-color:var(--bdr);color:var(--sub);}
.airdrop-desc{font-size:12px;color:var(--sub);line-height:1.55;}

/* POSTS (X, Reddit, YouTube) */
.post{padding:11px 16px;border-bottom:1px solid var(--bdr);cursor:pointer;transition:background .1s;}
.post:last-child{border-bottom:none;}
.post:hover{background:rgba(0,85,255,.02);}
.post-src{font-size:9px;font-weight:700;letter-spacing:.04em;padding:1px 7px;border-radius:4px;display:inline-block;margin-bottom:4px;}
.src-x{background:rgba(0,85,255,.07);color:var(--blue);}
.src-reddit{background:rgba(229,62,62,.07);color:var(--red);}
.src-yt{background:rgba(229,62,62,.09);color:#c0000a;}
.src-gh{background:rgba(15,40,80,.06);color:#3d4555;}
.src-trends{background:rgba(0,196,140,.07);color:#008f6e;}
.post-text{font-size:12px;color:var(--text);line-height:1.5;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;margin-bottom:4px;}
.post-meta{font-size:11px;color:var(--sub);display:flex;align-items:center;gap:8px;}
.post-user{color:var(--blue);font-weight:600;}
.post-score{color:var(--green);font-weight:700;}
.post-sub{font-size:10px;background:var(--muted);padding:1px 6px;border-radius:4px;color:var(--sub);}

/* NEW PROJECTS */
.repo{padding:11px 16px;border-bottom:1px solid var(--bdr);}
.repo:last-child{border-bottom:none;}
.repo-top{display:flex;align-items:center;gap:8px;margin-bottom:3px;}
.repo-name{font-size:13px;font-weight:700;color:var(--text);}
.repo-stars{font-size:11px;font-weight:700;color:#f5a623;}
.repo-topic{font-size:9px;font-weight:700;padding:1px 7px;border-radius:4px;background:rgba(100,60,200,.07);color:#5030b0;border:1px solid rgba(100,60,200,.15);}
.repo-desc{font-size:12px;color:var(--sub);line-height:1.5;}

/* GOOGLE TRENDS */
.trend{display:flex;align-items:center;gap:10px;padding:9px 16px;border-bottom:1px solid var(--bdr);}
.trend:last-child{border-bottom:none;}
.trend-rank{font-size:11px;font-weight:700;color:var(--sub);width:18px;text-align:center;flex-shrink:0;}
.trend-info{flex:1;}
.trend-term{font-size:13px;font-weight:700;}
.trend-ctx{font-size:11px;color:var(--sub);}
.trend-vol{font-size:11px;font-weight:700;color:var(--blue);white-space:nowrap;}

/* INSIGHT BOXES */
.insight{padding:12px 16px;font-size:13px;color:var(--sub);line-height:1.65;}
.insight strong{color:var(--text);}

/* SPINNER / EMPTY */
.loading{padding:28px;text-align:center;color:var(--sub);font-size:13px;}
.sp{display:inline-block;width:16px;height:16px;border:2px solid var(--bdr);border-top-color:var(--blue);border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle;margin-right:7px;}
@keyframes spin{to{transform:rotate(360deg)}}
.empty{padding:22px 16px;text-align:center;color:var(--sub);font-size:13px;line-height:1.7;}
.setup{background:#fffbeb;border:1px solid rgba(232,176,32,.3);border-radius:12px;padding:16px 20px;margin-bottom:20px;font-size:13px;line-height:1.75;color:#7a5800;}
.setup code{background:rgba(0,0,0,.07);padding:1px 6px;border-radius:4px;font-size:12px;}

@media(max-width:1050px){.grid{grid-template-columns:1fr 1fr;}}
@media(max-width:680px){.grid,.grid-wide{grid-template-columns:1fr;}.hero{padding:20px 18px;}}
</style>
</head>
<body>

<nav class="nav">
  <a href="index.html" class="brand" style="display:flex;align-items:center;gap:8px;text-decoration:none;"><div style="width:28px;height:28px;border-radius:7px;background:linear-gradient(145deg,#1c6fff 0%,#0a44dd 42%,#0025a0 100%);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;flex-shrink:0;box-shadow:0 4px 16px rgba(8,48,200,.45),inset 0 0 0 1px rgba(255,255,255,.12);"><div style="position:absolute;inset:0;background:radial-gradient(ellipse at 36% 22%,rgba(255,255,255,.26) 0%,transparent 52%);pointer-events:none;"></div><svg width="19" height="19" viewBox="0 0 200 200" fill="none" style="position:relative;z-index:1"><path d="M100 12 C100 12 116 70 130 84 C144 98 188 100 188 100 C188 100 144 102 130 116 C116 130 100 188 100 188 C100 188 84 130 70 116 C56 102 12 100 12 100 C12 100 56 98 70 84 C84 70 100 12 100 12Z" fill="white"/></svg></div> <span style="font-size:14px;font-weight:800;color:#0a1929;letter-spacing:-.02em;">Astro</span></a>
  <div class="nav-sep"></div>
  <span class="nav-label"><span class="live-dot"></span>Trending Intelligence</span>
  <span class="nav-updated" id="nav-updated"></span>
  <a href="dashboard.html" class="nav-back">← Dashboard</a>
</nav>

<div class="wrap">

    <!-- HERO -->
  <div class="hero" id="hero">
    <div class="loading"><span class="sp"></span>Loading intelligence report...</div>
  </div>

  <!-- TOP ROW: Narratives + Airdrops + Themes -->
  <div class="grid">

    <div class="card">
      <div class="card-hd">
        <div class="card-title">🧠 Top narratives</div>
        <div class="badge b-blue">AI ANALYSIS</div>
      </div>
      <div id="narratives"><div class="loading"><span class="sp"></span></div></div>
    </div>

    <div class="card">
      <div class="card-hd">
        <div class="card-title">🪂 Hot airdrops this week</div>
        <div class="badge b-teal">AI PICKED</div>
      </div>
      <div id="airdrops"><div class="loading"><span class="sp"></span></div></div>
    </div>

    <div class="card">
      <div class="card-hd">
        <div class="card-title">💬 Trending themes</div>
        <div class="badge b-blue">AI</div>
      </div>
      <div id="themes"><div class="loading"><span class="sp"></span></div></div>
      <!-- Insights -->
      <div class="card-hd" style="border-top:1px solid var(--bdr);border-radius:0;margin-top:0;">
        <div class="card-title">📺 YouTube pulse</div>
      </div>
      <div id="yt-pulse"><div class="loading"><span class="sp"></span></div></div>
      <div class="card-hd" style="border-top:1px solid var(--bdr);border-radius:0;">
        <div class="card-title">🔍 Google signal</div>
      </div>
      <div id="google-signal"><div class="loading"><span class="sp"></span></div></div>
    </div>

  </div>

  <!-- BOTTOM ROW -->
  <div class="grid-wide">

    <!-- LEFT: X + Reddit tabbed -->
    <div class="card" style="border-radius:12px;overflow:hidden;">
      <div class="tabs" id="tabs">
        <button class="tab on" data-tab="x"><span class="tab-icon">🐦</span>X / Twitter</button>
        <button class="tab" data-tab="reddit-airdrops"><span class="tab-icon">🔴</span>r/airdrops</button>
        <button class="tab" data-tab="reddit-crypto"><span class="tab-icon">💬</span>r/crypto</button>
        <button class="tab" data-tab="reddit-moon"><span class="tab-icon">🚀</span>r/MoonShots</button>
      </div>
      <div id="feed-x"><div class="loading"><span class="sp"></span>Loading X posts...</div></div>
      <div id="feed-reddit-airdrops" style="display:none"></div>
      <div id="feed-reddit-crypto" style="display:none"></div>
      <div id="feed-reddit-moon" style="display:none"></div>
    </div>

    <!-- RIGHT COL -->
    <div style="display:flex;flex-direction:column;gap:18px;">
      <div class="card">
        <div class="card-hd">
          <div class="card-title">💻 New projects — web3 & crypto</div>
          <div class="badge b-purple">WEEKLY NEW</div>
        </div>
        <div id="new-projects"><div class="loading"><span class="sp"></span></div></div>
      </div>
      <div class="card">
        <div class="card-hd">
          <div class="card-title">📊 Google Trends — crypto searches this week</div>
          <div class="badge b-green">7 DAYS</div>
        </div>
        <div id="gtrends"><div class="loading"><span class="sp"></span></div></div>
      </div>
    </div>

  </div>
</div>

<script>
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function ago(d){try{var m=Math.floor((Date.now()-new Date(d))/60000);if(m<1)return'just now';if(m<60)return m+'m ago';if(m<1440)return Math.floor(m/60)+'h ago';return Math.floor(m/1440)+'d ago';}catch(e){return '';}}

// ── HERO ──
function renderHero(a, updated){
  var el=document.getElementById('hero');
  if(!a){
    el.innerHTML='<div class="empty">Intelligence report is being prepared. Check back soon.</div>';
    return;
  }
  var rc='risk-'+(a.risk_level||'medium').toLowerCase();
  var h='<div class="hero-kicker">AI Intelligence Report · '+esc(updated||'')+'</div>';
  h+='<div class="hero-hl">'+esc(a.headline||'')+'</div>';
  if(a.summary)h+='<div class="hero-summary">'+esc(a.summary)+'</div>';
  h+='<div class="hero-row">';
  if(a.risk_level)h+='<span class="risk-pill '+rc+'">Risk: '+esc(a.risk_level.toUpperCase())+(a.risk_reason?' · '+esc(a.risk_reason):'')+'</span>';
  h+='</div>';
  if(a.analyst_take)h+='<div class="analyst"><strong>Analyst take:</strong> '+esc(a.analyst_take)+'</div>';
  el.innerHTML=h;
}

// ── NARRATIVES ──
function renderNarratives(a){
  var w=document.getElementById('narratives');
  var items=(a&&a.top_narratives)||[];
  w.innerHTML=items.length?'<div class="narratives">'+items.map(function(n){return'<div class="npill">'+esc(n)+'</div>';}).join('')+'</div>':'<div class="empty">No data yet.</div>';
}

// ── THEMES ──
function renderThemes(a){
  var w=document.getElementById('themes');
  var items=(a&&a.trending_themes)||[];
  w.innerHTML=items.length?'<div class="themes">'+items.map(function(t){return'<div class="theme">'+esc(t)+'</div>';}).join('')+'</div>':'<div class="empty">No themes yet.</div>';
}

// ── AIRDROPS ──
function renderAirdrops(a){
  var w=document.getElementById('airdrops');
  var items=(a&&a.hot_airdrops)||[];
  if(!items.length){w.innerHTML='<div class="empty">No airdrops yet.</div>';return;}
  var h='';
  items.forEach(function(x){
    var hc='hype-'+(x.hype||'medium').toLowerCase();
    h+='<div class="airdrop"><div class="airdrop-top"><span class="airdrop-name">'+esc(x.name)+'</span><span class="airdrop-tags">';
    if(x.status)h+='<span class="a-status'+(x.status.toLowerCase()==='ended'?' a-ended':'')+'">'+esc(x.status)+'</span>';
    if(x.hype)h+='<span class="'+hc+'">'+esc(x.hype)+'</span>';
    h+='</span></div>';
    if(x.description)h+='<div class="airdrop-desc">'+esc(x.description)+'</div>';
    h+='</div>';
  });
  w.innerHTML=h;
}

// ── INSIGHTS ──
function renderInsights(a){
  var yp=document.getElementById('yt-pulse');
  var gs=document.getElementById('google-signal');
  if(yp)yp.innerHTML=a&&a.youtube_pulse?'<div class="insight">'+esc(a.youtube_pulse)+'</div>':'<div class="empty">No data.</div>';
  if(gs)gs.innerHTML=a&&a.google_signal?'<div class="insight">'+esc(a.google_signal)+'</div>':'<div class="empty">No data.</div>';
}

// ── X POSTS ──
function renderX(posts){
  var w=document.getElementById('feed-x');
  if(!posts||!posts.length){w.innerHTML='<div class="empty">No X posts found.<br><small>Nitter instances may be temporarily unavailable.</small></div>';return;}
  var h='';
  posts.slice(0,14).forEach(function(p){
    h+='<div class="post" onclick="window.open(\''+esc(p.link)+'\',\'_blank\')">';
    h+='<div class="post-src src-x">'+esc(p.query||'X/Twitter')+'</div>';
    h+='<div class="post-text">'+esc(p.text)+'</div>';
    h+='<div class="post-meta">'+(p.user&&p.user!=='unknown'?'<span class="post-user">@'+esc(p.user)+'</span>':'')+' <span>'+esc(ago(p.date))+'</span></div>';
    h+='</div>';
  });
  w.innerHTML=h;
}

// ── REDDIT ──
function renderReddit(posts, elId, sub){
  var w=document.getElementById(elId);
  if(!posts||!posts.length){w.innerHTML='<div class="empty">No posts from r/'+esc(sub)+' yet.</div>';return;}
  var h='';
  posts.forEach(function(p){
    h+='<div class="post" onclick="window.open(\''+esc(p.url)+'\',\'_blank\')">';
    if(p.flair)h+='<div class="post-src src-reddit">'+esc(p.flair)+'</div>';
    else h+='<div class="post-src src-reddit">r/'+esc(sub)+'</div>';
    h+='<div class="post-text">'+esc(p.title)+'</div>';
    h+='<div class="post-meta"><span class="post-score">▲ '+esc(p.score)+'</span><span>💬 '+esc(p.comments)+'</span></div>';
    h+='</div>';
  });
  w.innerHTML=h;
}

// ── GITHUB ──
function renderNewProjects(repos){
  var w=document.getElementById('new-projects');
  if(!repos||!repos.length){w.innerHTML='<div class="empty">No new projects found yet.</div>';return;}
  var h='';
  repos.forEach(function(r){
    h+='<div class="repo">';
    h+='<div class="repo-top"><span class="repo-name">'+esc(r.repo)+'</span>';
    h+='<span class="repo-stars">⭐ '+esc(r.stars)+'</span>';
    h+='<span class="repo-topic">'+esc(r.topic)+'</span></div>';
    if(r.desc)h+='<div class="repo-desc">'+esc(r.desc)+'</div>';
    h+='</div>';
  });
  w.innerHTML=h;
}

// ── GOOGLE TRENDS ──
function renderTrends(trends){
  var w=document.getElementById('gtrends');
  if(!trends||!trends.length){w.innerHTML='<div class="empty">No trends data yet.</div>';return;}
  var h='';
  trends.forEach(function(t,i){
    h+='<div class="trend"><div class="trend-rank">'+(i+1)+'</div>';
    h+='<div class="trend-info"><div class="trend-term">'+esc(t.term)+'</div>';
    if(t.context)h+='<div class="trend-ctx">'+esc(t.context)+'</div>';
    h+='</div>';
    if(t.traffic)h+='<div class="trend-vol">'+esc(t.traffic)+'</div>';
    h+='</div>';
  });
  w.innerHTML=h;
}

// ── TABS ──
document.querySelectorAll('.tab').forEach(function(tab){
  tab.addEventListener('click',function(){
    document.querySelectorAll('.tab').forEach(function(t){t.classList.remove('on');});
    tab.classList.add('on');
    var key=tab.getAttribute('data-tab');
    ['feed-x','feed-reddit-airdrops','feed-reddit-crypto','feed-reddit-moon'].forEach(function(id){
      document.getElementById(id).style.display='none';
    });
    var target=document.getElementById('feed-'+key);
    if(target)target.style.display='block';
  });
});

// ── LOAD ──
function load(){
  fetch('data/trending.json?t='+Date.now(),{cache:'no-store'})
    .then(function(r){if(!r.ok)throw new Error(r.status);return r.json();})
    .then(function(d){
      var nu=document.getElementById('nav-updated');
      if(nu&&d.updated)nu.textContent=d.updated;
      var empty=!d.analysis&&!(d.x_posts||[]).length;
      

      renderHero(d.analysis,d.updated);
      renderNarratives(d.analysis);
      renderThemes(d.analysis);
      renderAirdrops(d.analysis);
      renderInsights(d.analysis);
      renderX(d.x_posts||[]);

      var r=d.reddit||{};
      renderReddit(r.airdrops||[],        'feed-reddit-airdrops','airdrops');
      renderReddit(r.CryptoCurrency||[],  'feed-reddit-crypto',  'CryptoCurrency');
      renderReddit(r.CryptoMoonShots||[], 'feed-reddit-moon',    'CryptoMoonShots');

      renderNewProjects(d.github||[]);
      renderTrends(d.google_trends||[]);
    })
    .catch(function(){
      document.getElementById('hero').innerHTML='<div class="empty">Data is loading. Please check back shortly.</div>';
    });
}

load();
setInterval(load, 10*60*1000);
</script>
